# =====================================================================
# Story Management Dashboard — Environment Variables Template
# =====================================================================
# Copy this file to ".env" and fill in your actual values.
# The ".env" file is listed in .gitignore and will NOT be committed to Git.
#
# Supabase Project Credentials
# Found in: Supabase Dashboard → Project Settings → API
# =====================================================================

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Cloudflare R2 Upload Worker URL
# Setup a Cloudflare Worker to securely proxy file uploads to R2 bucket.
# Leave blank to disable R2 uploads button fallback.
VITE_R2_UPLOAD_WORKER_URL=https://your-worker.your-subdomain.workers.dev

